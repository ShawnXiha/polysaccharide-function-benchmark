# Keep compiled deliverables, ignore transient lock/cache files
~$*
*.tmp
*.lock

# Generated PyTorch payloads are reproducible from CSV exports and schemas.
# Keep JSON summaries / feature schemas, but do not commit large .pt blobs.
data/processed/pyg/*.pt
paper/slides/tmp/

# OS/editor
.DS_Store
Thumbs.db
.vscode/
.idea/
